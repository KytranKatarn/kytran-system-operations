{
  "pack_id": "cis-ubuntu-22.04",
  "name": "CIS Ubuntu 22.04 Benchmark",
  "description": "Center for Internet Security Benchmark for Ubuntu 22.04 LTS \u2014 enterprise-grade hardening rules",
  "version": "1.0",
  "category": "os",
  "source": "CIS",
  "rules": [
    {
      "rule_id": "CIS-1.1.1",
      "severity": "low",
      "title": "Ensure mounting of cramfs is disabled",
      "description": "The cramfs filesystem type is a compressed read-only Linux filesystem. Removing support reduces the local attack surface.",
      "check": {
        "type": "file_contains",
        "path": "/etc/modprobe.d/cramfs.conf",
        "expected": "/bin/true"
      },
      "fix": {
        "type": "command",
        "command": "echo 'install cramfs /bin/true' >> /etc/modprobe.d/CIS.conf && rmmod cramfs 2>/dev/null; true",
        "risk": "low"
      },
      "soc2_mapping": [
        "CC6.1"
      ],
      "cis_section": "1.1.1"
    },
    {
      "rule_id": "CIS-1.1.2",
      "severity": "low",
      "title": "Ensure mounting of squashfs is disabled",
      "description": "The squashfs filesystem type is a compressed read-only Linux filesystem. Disabling reduces the local attack surface.",
      "check": {
        "type": "file_contains",
        "path": "/etc/modprobe.d/squashfs.conf",
        "expected": "/bin/true"
      },
      "fix": {
        "type": "command",
        "command": "echo 'install squashfs /bin/true' >> /etc/modprobe.d/CIS.conf && rmmod squashfs 2>/dev/null; true",
        "risk": "low"
      },
      "soc2_mapping": [
        "CC6.1"
      ],
      "cis_section": "1.1.2"
    },
    {
      "rule_id": "CIS-1.1.3",
      "severity": "low",
      "title": "Ensure mounting of udf is disabled",
      "description": "The udf filesystem type is the Universal Disk Format used for DVDs/Blu-ray. Disabling reduces the local attack surface.",
      "check": {
        "type": "file_contains",
        "path": "/etc/modprobe.d/udf.conf",
        "expected": "/bin/true"
      },
      "fix": {
        "type": "command",
        "command": "echo 'install udf /bin/true' >> /etc/modprobe.d/CIS.conf && rmmod udf 2>/dev/null; true",
        "risk": "low"
      },
      "soc2_mapping": [
        "CC6.1"
      ],
      "cis_section": "1.1.3"
    },
    {
      "rule_id": "CIS-1.1.4",
      "severity": "medium",
      "title": "Ensure /tmp is a separate partition",
      "description": "The /tmp directory should be on a separate partition to prevent resource exhaustion attacks against the root filesystem.",
      "check": {
        "type": "file_contains",
        "path": "/host/proc/mounts",
        "expected": "/tmp"
      },
      "fix": {
        "type": "command",
        "command": "echo 'tmpfs /tmp tmpfs defaults,rw,nosuid,nodev,noexec,relatime,size=2G 0 0' >> /etc/fstab && mount -o remount /tmp 2>/dev/null; true",
        "risk": "medium"
      },
      "soc2_mapping": [
        "CC6.1",
        "CC7.1"
      ],
      "cis_section": "1.1.4"
    },
    {
      "rule_id": "CIS-1.1.5",
      "severity": "medium",
      "title": "Ensure noexec option set on /tmp",
      "description": "The noexec mount option prevents execution of binaries on /tmp, mitigating temp-based attacks.",
      "check": {
        "type": "file_contains",
        "path": "/host/proc/mounts",
        "expected": "noexec",
        "match_line": "/tmp"
      },
      "fix": {
        "type": "command",
        "command": "mount -o remount,noexec /tmp 2>/dev/null; true",
        "risk": "medium"
      },
      "soc2_mapping": [
        "CC6.1"
      ],
      "cis_section": "1.1.5"
    },
    {
      "rule_id": "CIS-1.1.6",
      "severity": "medium",
      "title": "Ensure nosuid option set on /tmp",
      "description": "The nosuid mount option prevents setuid programs from running on /tmp.",
      "check": {
        "type": "file_contains",
        "path": "/host/proc/mounts",
        "expected": "nosuid",
        "match_line": "/tmp"
      },
      "fix": {
        "type": "command",
        "command": "mount -o remount,nosuid /tmp 2>/dev/null; true",
        "risk": "medium"
      },
      "soc2_mapping": [
        "CC6.1"
      ],
      "cis_section": "1.1.6"
    },
    {
      "rule_id": "CIS-1.1.7",
      "severity": "medium",
      "title": "Ensure nodev option set on /tmp",
      "description": "The nodev mount option prevents device files from being created on /tmp.",
      "check": {
        "type": "file_contains",
        "path": "/host/proc/mounts",
        "expected": "nodev",
        "match_line": "/tmp"
      },
      "fix": {
        "type": "command",
        "command": "mount -o remount,nodev /tmp 2>/dev/null; true",
        "risk": "medium"
      },
      "soc2_mapping": [
        "CC6.1"
      ],
      "cis_section": "1.1.7"
    },
    {
      "rule_id": "CIS-1.1.8",
      "severity": "low",
      "title": "Ensure separate /var partition exists",
      "description": "The /var directory should be on a separate partition to prevent resource exhaustion from logs/temp data.",
      "check": {
        "type": "file_contains",
        "path": "/host/proc/mounts",
        "expected": "/var"
      },
      "fix": {
        "type": "command",
        "command": "echo 'INFO: /var partition must be configured during OS installation or via LVM migration'",
        "risk": "high"
      },
      "soc2_mapping": [
        "CC6.1",
        "CC7.1"
      ],
      "cis_section": "1.1.8"
    },
    {
      "rule_id": "CIS-3.1.1",
      "severity": "medium",
      "title": "Ensure IP forwarding is disabled",
      "description": "IP forwarding should be disabled unless the system is a router. CIS checks both IPv4 and IPv6. Note: ip_forward=1 is required on Docker hosts.",
      "check": {
        "type": "command_output",
        "command": "sysctl -n net.ipv4.ip_forward",
        "match_pattern": "^[01]$",
        "expected": "0 or 1 (1 required for Docker hosts)",
        "docker_exception": true
      },
      "fix": {
        "type": "sysctl",
        "param": "net.ipv4.ip_forward",
        "value": "0",
        "risk": "low"
      },
      "soc2_mapping": [
        "CC6.1",
        "CC6.6"
      ],
      "cis_section": "3.1.1"
    },
    {
      "rule_id": "CIS-3.1.2",
      "severity": "medium",
      "title": "Ensure packet redirect sending is disabled",
      "description": "ICMP redirects should not be sent by a non-router system to prevent MITM attacks.",
      "check": {
        "type": "sysctl_value",
        "param": "net.ipv4.conf.all.send_redirects",
        "expected": "0"
      },
      "fix": {
        "type": "sysctl",
        "param": "net.ipv4.conf.all.send_redirects",
        "value": "0",
        "risk": "low"
      },
      "soc2_mapping": [
        "CC6.1",
        "CC6.6"
      ],
      "cis_section": "3.1.2"
    },
    {
      "rule_id": "CIS-3.2.1",
      "severity": "medium",
      "title": "Ensure source routed packets are not accepted",
      "description": "Source routed packets allow the sender to specify the route, which can be used to bypass network security.",
      "check": {
        "type": "sysctl_value",
        "param": "net.ipv4.conf.all.accept_source_route",
        "expected": "0"
      },
      "fix": {
        "type": "sysctl",
        "param": "net.ipv4.conf.all.accept_source_route",
        "value": "0",
        "risk": "low"
      },
      "soc2_mapping": [
        "CC6.1",
        "CC6.6"
      ],
      "cis_section": "3.2.1"
    },
    {
      "rule_id": "CIS-3.2.2",
      "severity": "medium",
      "title": "Ensure ICMP redirects are not accepted",
      "description": "ICMP redirect messages can be used by an attacker to alter routing tables.",
      "check": {
        "type": "sysctl_value",
        "param": "net.ipv4.conf.all.accept_redirects",
        "expected": "0"
      },
      "fix": {
        "type": "sysctl",
        "param": "net.ipv4.conf.all.accept_redirects",
        "value": "0",
        "risk": "low"
      },
      "soc2_mapping": [
        "CC6.1",
        "CC6.6"
      ],
      "cis_section": "3.2.2"
    },
    {
      "rule_id": "CIS-3.2.3",
      "severity": "medium",
      "title": "Ensure secure ICMP redirects are not accepted",
      "description": "Secure ICMP redirects from known gateways should still be rejected to prevent route table manipulation.",
      "check": {
        "type": "sysctl_value",
        "param": "net.ipv4.conf.all.secure_redirects",
        "expected": "0"
      },
      "fix": {
        "type": "sysctl",
        "param": "net.ipv4.conf.all.secure_redirects",
        "value": "0",
        "risk": "low"
      },
      "soc2_mapping": [
        "CC6.1",
        "CC6.6"
      ],
      "cis_section": "3.2.3"
    },
    {
      "rule_id": "CIS-3.2.4",
      "severity": "medium",
      "title": "Ensure suspicious packets are logged (log_martians)",
      "description": "Logging martian packets helps detect spoofing and routing configuration issues.",
      "check": {
        "type": "sysctl_value",
        "param": "net.ipv4.conf.all.log_martians",
        "expected": "1"
      },
      "fix": {
        "type": "sysctl",
        "param": "net.ipv4.conf.all.log_martians",
        "value": "1",
        "risk": "low"
      },
      "soc2_mapping": [
        "CC6.1",
        "CC7.2",
        "P1.2"
      ],
      "cis_section": "3.2.4"
    },
    {
      "rule_id": "CIS-3.3.1",
      "severity": "medium",
      "title": "Ensure IPv6 router advertisements are not accepted",
      "description": "IPv6 router advertisements can be spoofed to redirect traffic. Disable unless using SLAAC.",
      "check": {
        "type": "file_contains",
        "path": "/etc/sysctl.d/99-cis-hardening.conf",
        "expected": "net.ipv6.conf.all.accept_ra = 0"
      },
      "fix": {
        "type": "sysctl",
        "param": "net.ipv6.conf.all.accept_ra",
        "value": "0",
        "risk": "low"
      },
      "soc2_mapping": [
        "CC6.1",
        "CC6.6"
      ],
      "cis_section": "3.3.1"
    },
    {
      "rule_id": "CIS-3.3.2",
      "severity": "medium",
      "title": "Ensure IPv6 redirects are not accepted",
      "description": "IPv6 redirect messages can alter routing tables. Disable to prevent MITM attacks.",
      "check": {
        "type": "file_contains",
        "path": "/etc/sysctl.d/99-cis-hardening.conf",
        "expected": "net.ipv6.conf.all.accept_redirects = 0"
      },
      "fix": {
        "type": "sysctl",
        "param": "net.ipv6.conf.all.accept_redirects",
        "value": "0",
        "risk": "low"
      },
      "soc2_mapping": [
        "CC6.1",
        "CC6.6"
      ],
      "cis_section": "3.3.2"
    },
    {
      "rule_id": "CIS-4.1.1",
      "severity": "high",
      "title": "Ensure auditd is installed",
      "description": "auditd is the Linux Audit daemon that records security-relevant events on the system.",
      "check": {
        "type": "package_installed",
        "package": "auditd"
      },
      "fix": {
        "type": "command",
        "command": "apt-get install -y auditd audispd-plugins",
        "risk": "low"
      },
      "soc2_mapping": [
        "CC6.1",
        "CC7.2",
        "CC7.3",
        "P1.2"
      ],
      "cis_section": "4.1.1"
    },
    {
      "rule_id": "CIS-4.1.2",
      "severity": "high",
      "title": "Ensure auditd service is enabled and running",
      "description": "The auditd service must be enabled to collect audit records.",
      "check": {
        "type": "command_output",
        "command": "systemctl is-enabled auditd 2>/dev/null || echo 'disabled'",
        "expected": "enabled",
        "match": "exact"
      },
      "fix": {
        "type": "command",
        "command": "systemctl enable --now auditd",
        "risk": "low"
      },
      "soc2_mapping": [
        "CC6.1",
        "CC7.2",
        "P1.2"
      ],
      "cis_section": "4.1.2"
    },
    {
      "rule_id": "CIS-4.1.3",
      "severity": "medium",
      "title": "Ensure audit log storage size is configured",
      "description": "The max_log_file parameter in auditd.conf should be set to ensure adequate log storage.",
      "check": {
        "type": "file_content",
        "path": "/etc/audit/auditd.conf",
        "pattern": "^max_log_file\\s*=",
        "expected": "max_log_file"
      },
      "fix": {
        "type": "file_line",
        "path": "/etc/audit/auditd.conf",
        "line": "max_log_file = 256",
        "restart_service": "auditd",
        "risk": "low"
      },
      "soc2_mapping": [
        "CC7.2",
        "CC7.3",
        "P1.2"
      ],
      "cis_section": "4.1.3"
    },
    {
      "rule_id": "CIS-4.2.1",
      "severity": "medium",
      "title": "Ensure rsyslog is installed",
      "description": "rsyslog provides reliable syslog message transport and storage for system logging.",
      "check": {
        "type": "file_contains",
        "path": "/host/etc/rsyslog.conf",
        "expected": "rsyslog"
      },
      "fix": {
        "type": "command",
        "command": "apt-get install -y rsyslog",
        "risk": "low"
      },
      "soc2_mapping": [
        "CC7.2",
        "CC7.3",
        "P1.2"
      ],
      "cis_section": "4.2.1"
    },
    {
      "rule_id": "CIS-4.2.2",
      "severity": "medium",
      "title": "Ensure rsyslog service is enabled",
      "description": "The rsyslog service must be enabled to collect system logs.",
      "check": {
        "type": "file_contains",
        "path": "/host/etc/rsyslog.conf",
        "expected": "imuxsock"
      },
      "fix": {
        "type": "command",
        "command": "systemctl enable --now rsyslog",
        "risk": "low"
      },
      "soc2_mapping": [
        "CC7.2",
        "P1.2"
      ],
      "cis_section": "4.2.2"
    },
    {
      "rule_id": "CIS-4.2.3",
      "severity": "medium",
      "title": "Ensure rsyslog default file permissions are configured",
      "description": "rsyslog should create log files with restrictive permissions (0640).",
      "check": {
        "type": "file_permission",
        "path": "/host/etc/rsyslog.conf",
        "expected_mode": "0640"
      },
      "fix": {
        "type": "file_line",
        "path": "/etc/rsyslog.conf",
        "line": "$FileCreateMode 0640",
        "restart_service": "rsyslog",
        "risk": "low"
      },
      "soc2_mapping": [
        "C1.2",
        "CC6.1",
        "CC7.2",
        "P1.2"
      ],
      "cis_section": "4.2.3"
    },
    {
      "rule_id": "CIS-4.2.4",
      "severity": "medium",
      "title": "Ensure journald is configured to send logs to rsyslog",
      "description": "Data from journald should be forwarded to rsyslog for centralized log management.",
      "check": {
        "type": "file_contains",
        "path": "/host/etc/journald.conf",
        "expected": "ForwardToSyslog=yes"
      },
      "fix": {
        "type": "file_line",
        "path": "/etc/systemd/journald.conf",
        "line": "ForwardToSyslog=yes",
        "restart_service": "systemd-journald",
        "risk": "low"
      },
      "soc2_mapping": [
        "CC7.2",
        "P1.2"
      ],
      "cis_section": "4.2.4"
    },
    {
      "rule_id": "CIS-4.2.5",
      "severity": "medium",
      "title": "Ensure remote logging is configured",
      "description": "System logs should be sent to a remote log host to preserve evidence and ensure availability.",
      "check": {
        "type": "file_contains",
        "path": "/host/etc/rsyslog.conf",
        "expected": "@@"
      },
      "fix": {
        "type": "command",
        "command": "echo 'INFO: Configure remote syslog destination in /etc/rsyslog.conf \u2014 *.* @@<remote-host>:514'",
        "risk": "high"
      },
      "soc2_mapping": [
        "CC7.2",
        "CC7.3",
        "CC7.4",
        "P1.2"
      ],
      "cis_section": "4.2.5"
    },
    {
      "rule_id": "CIS-5.1.1",
      "severity": "medium",
      "title": "Ensure cron daemon is enabled and running",
      "description": "The cron daemon is used for scheduled jobs and must be running for system maintenance tasks.",
      "check": {
        "type": "file_permission",
        "path": "/host/etc/crontab",
        "expected_mode": "0600",
        "expected_owner": "root"
      },
      "fix": {
        "type": "command",
        "command": "systemctl enable --now cron",
        "risk": "low"
      },
      "soc2_mapping": [
        "CC7.1"
      ],
      "cis_section": "5.1.1"
    },
    {
      "rule_id": "CIS-5.1.2",
      "severity": "medium",
      "title": "Ensure permissions on /etc/crontab are configured",
      "description": "The /etc/crontab file should be owned by root with restrictive permissions (0600).",
      "check": {
        "type": "file_permission",
        "path": "/host/etc/crontab",
        "expected_mode": "0600"
      },
      "fix": {
        "type": "command",
        "command": "chown root:root /etc/crontab && chmod 0600 /etc/crontab",
        "risk": "low"
      },
      "soc2_mapping": [
        "C1.2",
        "CC6.1"
      ],
      "cis_section": "5.1.2"
    },
    {
      "rule_id": "CIS-5.2.1",
      "severity": "medium",
      "title": "Ensure sudo is installed",
      "description": "sudo allows controlled privilege escalation and must be installed for auditable administrative access.",
      "check": {
        "type": "file_contains",
        "path": "/host/etc/sudoers",
        "expected": "Defaults"
      },
      "fix": {
        "type": "command",
        "command": "apt-get install -y sudo",
        "risk": "low"
      },
      "soc2_mapping": [
        "CC6.1",
        "CC6.2",
        "CC6.3"
      ],
      "cis_section": "5.2.1"
    },
    {
      "rule_id": "CIS-5.2.2",
      "severity": "medium",
      "title": "Ensure sudo log file exists",
      "description": "A custom log file for sudo provides additional audit trail for privileged commands.",
      "check": {
        "type": "file_contains",
        "path": "/host/etc/sudoers.d/logging",
        "expected": "logfile"
      },
      "fix": {
        "type": "command",
        "command": "echo 'Defaults logfile=\"/var/log/sudo.log\"' >> /etc/sudoers.d/cis-logging",
        "risk": "low"
      },
      "soc2_mapping": [
        "CC6.1",
        "CC7.2",
        "P1.2"
      ],
      "cis_section": "5.2.2"
    },
    {
      "rule_id": "CIS-5.3.1",
      "severity": "high",
      "title": "Ensure password creation requirements are configured",
      "description": "Password policies should enforce minimum length and complexity via pam_pwquality.",
      "check": {
        "type": "file_content",
        "path": "/etc/security/pwquality.conf",
        "pattern": "^minlen",
        "expected": "minlen"
      },
      "fix": {
        "type": "command",
        "command": "apt-get install -y libpam-pwquality && sed -i 's/^# minlen.*/minlen = 14/' /etc/security/pwquality.conf",
        "risk": "low"
      },
      "soc2_mapping": [
        "CC6.1",
        "CC6.2"
      ],
      "cis_section": "5.3.1"
    },
    {
      "rule_id": "CIS-5.3.2",
      "severity": "high",
      "title": "Ensure lockout for failed password attempts is configured",
      "description": "Account lockout after repeated failures prevents brute-force attacks.",
      "check": {
        "type": "file_content",
        "path": "/etc/security/faillock.conf",
        "pattern": "deny\\s*=",
        "expected": "deny"
      },
      "fix": {
        "type": "command",
        "command": "echo 'deny = 5' >> /etc/security/faillock.conf && echo 'unlock_time = 900' >> /etc/security/faillock.conf",
        "risk": "low"
      },
      "soc2_mapping": [
        "CC6.1",
        "CC6.2",
        "P1.1"
      ],
      "cis_section": "5.3.2"
    },
    {
      "rule_id": "CIS-5.3.3",
      "severity": "medium",
      "title": "Ensure password reuse is limited",
      "description": "Users should not be able to reuse recent passwords. Enforce via pam_pwhistory.",
      "check": {
        "type": "file_content",
        "path": "/etc/pam.d/common-password",
        "pattern": "pam_pwhistory\\.so",
        "expected": "remember"
      },
      "fix": {
        "type": "command",
        "command": "echo 'password required pam_pwhistory.so remember=24' >> /etc/pam.d/common-password",
        "risk": "medium"
      },
      "soc2_mapping": [
        "CC6.1",
        "CC6.2"
      ],
      "cis_section": "5.3.3"
    },
    {
      "rule_id": "CIS-5.4.1",
      "severity": "medium",
      "title": "Ensure password expiration is 365 days or less",
      "description": "Password expiration forces periodic password changes to limit credential exposure.",
      "check": {
        "type": "file_content",
        "path": "/etc/login.defs",
        "pattern": "^PASS_MAX_DAYS",
        "expected": "365"
      },
      "fix": {
        "type": "file_line",
        "path": "/etc/login.defs",
        "line": "PASS_MAX_DAYS 365",
        "risk": "low"
      },
      "soc2_mapping": [
        "CC6.1",
        "CC6.2",
        "P1.1"
      ],
      "cis_section": "5.4.1"
    },
    {
      "rule_id": "CIS-6.1.1",
      "severity": "medium",
      "title": "Ensure permissions on /etc/passwd are 644 or more restrictive",
      "description": "The /etc/passwd file must be readable but only writable by root.",
      "check": {
        "type": "file_permission",
        "path": "/etc/passwd",
        "max_mode": "0644"
      },
      "fix": {
        "type": "command",
        "command": "chmod 644 /etc/passwd && chown root:root /etc/passwd",
        "risk": "low"
      },
      "soc2_mapping": [
        "C1.2",
        "CC6.1"
      ],
      "cis_section": "6.1.1"
    },
    {
